# =============================================================
# .gitignore — Projeto HackGov PCD
# =============================================================

# ── Dependências ──────────────────────────────────────────────
node_modules/

# ── Build do frontend ─────────────────────────────────────────
build/
dist/
dist-ssr/
coverage/

# ── Build do backend .NET (gerado automaticamente, não commitar)
**/bin/
**/obj/
**/target/
*.class

# ── Variáveis de ambiente (NÃO commitar credenciais) ─────────
.env*
!.env.example

# ── Banco de dados SQLite ─────────────────────────────────────
*.db
*.db-shm
*.db-wal

# ── Logs ──────────────────────────────────────────────────────
*.log
npm-debug.log*

# ── IDEs ──────────────────────────────────────────────────────
.vs/
.vscode/settings.json
.idea/
*.suo
*.user

# ── OS ────────────────────────────────────────────────────────
.DS_Store
Thumbs.db

# ── TypeScript ────────────────────────────────────────────────
*.tsbuildinfo

# Supabase / artefatos locais
supabase/.temp/
supabase-schema.sql
