# Supabase - obtenha em https://supabase.com/dashboard/project/<seu-projeto>/settings/api
VITE_SUPABASE_URL=https://<seu-projeto>.supabase.co
VITE_SUPABASE_ANON_KEY=<sua-anon-key>

# Segredo da Edge Function classify-priority no Supabase, nao no frontend.
OPENROUTER_API_KEY=your_openrouter_api_key_here
